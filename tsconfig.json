{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": "./packages",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "paths": {
      "@/*": ["./packages/*"],
      "@core/*": ["./packages/core/*"],
      "@cli/*": ["./packages/cli/*"],
    },
  },
  "include": ["./packages/**/*.ts"],
  "exclude": [
    "node_modules",
    "libraries",
    "gh3sp-lib",
    "test-libraries",
    "gh3sp-ide",
    "gh3sp-ext",
    "packages/extension",
  ],
}
